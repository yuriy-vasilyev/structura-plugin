{
  "name": "structura/core",
  "description": "Autonomous AI Content Architect for Gutenberg",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4",
    "woocommerce/action-scheduler": "^3.9",
    "ext-json": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "Structura\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Structura\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit",
    "test:integration": "phpunit -c phpunit-integration.xml.dist"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "7.4"
    }
  },
  "authors": [
    {
      "name": "Xerx",
      "email": "hello@xerx.io"
    }
  ]
}
